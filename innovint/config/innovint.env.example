# ─── InnoVint Connector Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.

# Required: Your InnoVint tenant name (subdomain from your-tenant.innovint.us)
INNOVINT_TENANT=your-winery

# Required: Your PipesHub organization ID
INNOVINT_ORG_ID=org_xxxxxxxx

# ─── Authentication (choose one method) ─────────────────────────────────

# Method 1: API Key (recommended)
INNOVINT_AUTH_TYPE=api_key
INNOVINT_API_KEY=your-innovint-api-key-here

# Method 2: Bearer Token (OAuth)
# INNOVINT_AUTH_TYPE=bearer
# INNOVINT_BEARER_TOKEN=your-oauth-bearer-token-here

# ─── Optional: Override API base URL ────────────────────────────────────
# Only change this if InnoVint has provided you a custom API endpoint
# INNOVINT_BASE_URL=https://your-winery.innovint.us/api/v1

# ─── Sync Configuration ─────────────────────────────────────────────────

# How often to run incremental syncs (in minutes, min: 15, max: 1440)
INNOVINT_SYNC_INTERVAL=60

# Which entity types to sync (comma-separated)
# Available: lots,vessels,analyses,work_orders,case_goods,costs
INNOVINT_ENABLED_ENTITIES=lots,vessels,analyses,work_orders,case_goods,costs

# API pagination page size
INNOVINT_PAGE_SIZE=100

# Number of documents per ingestion batch
INNOVINT_BATCH_SIZE=50

# ─── Infrastructure ─────────────────────────────────────────────────────

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=innovint-connector

# Service
HEALTH_CHECK_PORT=8085
LOG_LEVEL=INFO
